{
  "manifest_version": 3,
  "name": "Web Archive Workbench Extension",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "contextMenus",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  }
}